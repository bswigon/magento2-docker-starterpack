# Ignore Magento files
/src/*
!/src/.gitkeep

# Ignore environment files
.env.local
.env.*.local

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Docker volumes data
/mysql/data/
/elasticsearch/data/
